---
import '../styles/global.css';
import { getAllStudies } from '../lib/studies.js';
import AppTabBar from '../components/AppTabBar.astro';
import AppWelcome from '../components/AppWelcome.astro';
import AppStudyBar from '../components/AppStudyBar.astro';
import AppTheme from '../components/AppTheme.astro';
import AppHome from '../components/AppHome.astro';
const totalStudies = getAllStudies().length;
const { title = 'Makor', description = 'Deep, Christ-centred study of every book of the Bible.', ogImage } = Astro.props;
const canonicalUrl = 'https://makor.co.za' + Astro.url.pathname;
const ogImageUrl = ogImage
  ? (ogImage.startsWith('http') ? ogImage : 'https://makor.co.za' + ogImage)
  : 'https://makor.co.za/og-default.png';
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    {description && <meta name="description" content={description} />}
    <meta property="og:site_name" content="Makor" />
    <meta property="og:title" content={title} />
    {description && <meta property="og:description" content={description} />}
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:image" content={ogImageUrl} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:image" content={ogImageUrl} />
    <link rel="canonical" href={canonicalUrl} />
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "WebSite",
      "name": "Makor",
      "alternateName": "Makor: back to the source",
      "url": "https://makor.co.za",
      "description": "Makor is a free, Christ-centred Bible study website offering a deep, careful study of every book of the Bible, showing how each passage points to Christ, made reachable for everyone."
    })} />
    <link rel="icon" href="/favicon.svg" />
    <meta name="makor:total-studies" content={String(totalStudies)} />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Fraunces:ital,opsz,wght@0,9..144,400;0,9..144,500;0,9..144,600;1,9..144,400;1,9..144,500&family=Newsreader:ital,opsz,wght@0,6..72,400;0,6..72,500;0,6..72,600;1,6..72,400;1,6..72,500&display=swap" rel="stylesheet" />
  </head>
  <body>
    <header class="site-header">
      <div class="wrap">
        <a class="wordmark" href="/" aria-label="Makor home">
          <svg class="brand-mark" viewBox="0 0 32 32" role="img" aria-hidden="true">
            <circle cx="16" cy="16" r="13.5" fill="none" stroke="#0F6C6C" stroke-width="1.4" opacity="0.35"/>
            <circle cx="16" cy="16" r="9.5" fill="none" stroke="#0F6C6C" stroke-width="1.4" opacity="0.6"/>
            <circle cx="16" cy="16" r="5.3" fill="none" stroke="#0F6C6C" stroke-width="1.4"/>
            <circle cx="16" cy="16" r="2.1" fill="#B8862F"/>
          </svg>
          <span class="wordmark-text">Makor</span>
        </a>
        <div class="header-right">
          <button id="header-min" class="header-min" type="button" aria-label="Minimize header" aria-expanded="true" title="Minimize"><span class="hm-chev" aria-hidden="true"></span></button>
          <span class="descriptor">Deep, Christ-centred study of every book of the Bible.</span>
          <button id="toggle-all" class="header-toggle" type="button" hidden>Open all</button>
          <div class="menu-wrap">
            <button id="menu-btn" class="menu-btn" type="button" aria-label="Open menu" aria-expanded="false"><span></span><span></span><span></span></button>
            <nav id="menu" class="menu" hidden></nav>
          </div>
        </div>
      </div>
      <div class="search-wrap">
        <div class="wrap">
          <input id="site-search" class="site-search" type="search" autocomplete="off" spellcheck="false" placeholder="Search books, movements, references, or words" aria-label="Search the Bible" />
          <div id="search-results" class="search-results" role="listbox" hidden></div>
        </div>
      </div>
      <div class="progress-strip" id="progress-strip" hidden></div>
      <div id="signin-bar" class="signin-bar" hidden>
        <div class="wrap signin-bar-inner">
          <span class="signin-text">Save your progress across every study, free and always.</span>
          <span class="signin-actions">
            <button id="signin-google" class="signin-btn" type="button">Sign in with Google</button>
            <button id="signin-apple" class="signin-btn" type="button">Sign in with Apple</button>
            <button id="signin-dismiss" class="signin-dismiss" type="button" aria-label="Dismiss">✕</button>
          </span>
        </div>
      </div>
    </header>
    <main class="wrap">
      <slot />
    </main>
    <footer class="site-footer">
      <div class="wrap">
        <p class="motif">In Your light we see light. Psalm 36:9</p>
        <p>Makor. Every study an act of discipleship. Scripture text: Berean Standard Bible (BSB), public domain.</p>
        <p class="footer-links"><a href="/">Home</a> · <a href="/privacy/">Privacy Policy</a> · <a href="/terms/">Terms of Use</a></p>
      </div>
    </footer>
    <AppTheme />
    <AppTabBar />
    <AppWelcome />
    <AppStudyBar />
    <AppHome />
    <script>
      document.addEventListener('click', (e) => {
        const btn = e.target.closest('.lex');
        if (!btn) return;
        const pop = btn.nextElementSibling;
        if (!pop || !pop.classList.contains('lex-pop')) return;
        const open = pop.hasAttribute('hidden');
        if (open) { pop.removeAttribute('hidden'); btn.setAttribute('aria-expanded', 'true'); }
        else { pop.setAttribute('hidden', ''); btn.setAttribute('aria-expanded', 'false'); }
      });
    </script>

    <script is:inline type="module">
      import { createClient } from 'https://esm.sh/@supabase/supabase-js@2';
      const SUPABASE_URL = 'https://auth.makor.co.za';
      const SUPABASE_KEY = 'sb_publishable_Fw_szIELBE9uFJwvsRygbA_HAibhMmh';
      const client = createClient(SUPABASE_URL, SUPABASE_KEY);
      window.makorClient = client;

      const menuEl = document.getElementById('menu');
      const menuBtn = document.getElementById('menu-btn');
      function render(user) {
        updateSigninBar(user);
        if (!menuEl) return;
        menuEl.innerHTML = '';
        const home = document.createElement('a'); home.className = 'menu-item'; home.href = '/'; home.textContent = 'Home'; menuEl.appendChild(home);
        const plan = document.createElement('a'); plan.className = 'menu-item'; plan.href = '/plan/'; plan.textContent = 'Reading plan'; menuEl.appendChild(plan);
        // Group plans menu item held back until the feature is polished; the /groups/ page itself remains reachable by URL.
        const prog = document.createElement('a'); prog.className = 'menu-item'; prog.href = '/progress/'; prog.textContent = 'My progress'; menuEl.appendChild(prog);
        const prof = document.createElement('a'); prof.className = 'menu-item'; prof.href = '/profile/'; prof.textContent = 'My profile'; menuEl.appendChild(prof);
        const act = document.createElement('a'); act.className = 'menu-item'; act.href = '/activity/'; act.textContent = 'Friends'; menuEl.appendChild(act);
        const prefs = document.createElement('a'); prefs.className = 'menu-item'; prefs.href = '/email-preferences/'; prefs.textContent = 'Notification settings'; menuEl.appendChild(prefs);
        if (user && ['luyanda@fleetly.co.za'].indexOf(user.email) !== -1) {
          const adm = document.createElement('a'); adm.className = 'menu-item'; adm.href = '/admin/'; adm.textContent = 'Admin dashboard'; menuEl.appendChild(adm);
        }
        if (user) {
          const name = (user.user_metadata && (user.user_metadata.full_name || user.user_metadata.name)) || user.email || 'Signed in';
          const who = document.createElement('div'); who.className = 'menu-user'; who.textContent = 'Signed in as ' + name; menuEl.appendChild(who);
          const del = document.createElement('a'); del.className = 'menu-item'; del.href = '/delete-account/'; del.textContent = 'Delete account'; menuEl.appendChild(del);
          const out = document.createElement('button'); out.className = 'menu-item menu-action'; out.type = 'button'; out.textContent = 'Sign out';
          out.addEventListener('click', async () => { await client.auth.signOut(); location.reload(); });
          menuEl.appendChild(out);
        } else {
          const inb = document.createElement('button'); inb.className = 'menu-item menu-action'; inb.type = 'button'; inb.textContent = 'Sign in with Google';
          inb.addEventListener('click', async () => { await client.auth.signInWithOAuth({ provider: 'google', options: { redirectTo: window.location.href } }); });
          menuEl.appendChild(inb);
          const inbA = document.createElement('button'); inbA.className = 'menu-item menu-action'; inbA.type = 'button'; inbA.textContent = 'Sign in with Apple';
          inbA.addEventListener('click', async () => { await client.auth.signInWithOAuth({ provider: 'apple', options: { redirectTo: window.location.href } }); });
          menuEl.appendChild(inbA);
        }
      }
      if (menuBtn && menuEl) {
        menuBtn.addEventListener('click', (e) => {
          e.stopPropagation();
          const closed = menuEl.hasAttribute('hidden');
          if (closed) { menuEl.removeAttribute('hidden'); menuBtn.setAttribute('aria-expanded', 'true'); }
          else { menuEl.setAttribute('hidden', ''); menuBtn.setAttribute('aria-expanded', 'false'); }
        });
        document.addEventListener('click', (e) => {
          if (menuEl.hasAttribute('hidden')) return;
          if (menuEl.contains(e.target) || menuBtn.contains(e.target)) return;
          menuEl.setAttribute('hidden', ''); menuBtn.setAttribute('aria-expanded', 'false');
        });
      }

      window.makorSaveAttempt = async (row) => {
        const { data } = await client.auth.getUser();
        if (!data || !data.user) return { skipped: true };
        return client.from('attempts').insert({
          study_slug: row.slug, book: row.book, title: row.title,
          phase: row.phase, score: row.score, answers: row.answers || null,
        });
      };
      window.makorGetHistory = async (slug) => {
        const { data: u } = await client.auth.getUser();
        if (!u || !u.user) return [];
        const { data } = await client.from('attempts')
          .select('phase,score,created_at')
          .eq('study_slug', slug)
          .order('created_at', { ascending: true });
        return data || [];
      };

      window.makorAllAttempts = async () => {
        const { data: u } = await client.auth.getUser();
        if (!u || !u.user) return [];
        const { data } = await client.from('attempts')
          .select('study_slug,book,phase,score,created_at,title')
          .order('created_at', { ascending: true });
        return data || [];
      };
      window.makorAdminOverview = async () => {
        const { data, error } = await client.rpc('admin_overview');
        if (error) return { error: true };
        return data || [];
      };
      window.makorAnalytics = async (days) => {
        const { data, error } = await client.rpc('admin_analytics', { p_days: days || 7 });
        if (error) return { error: true };
        return data || {};
      };

      // Cookieless page-view beacon. One per page load. No cookies, no cross-site.
      (async () => {
        try {
          const TRACK_URL = 'https://oztgjzncxgobcszcwibp.supabase.co/functions/v1/track';
          let sid = sessionStorage.getItem('mk_sid');
          if (!sid) { sid = (crypto.randomUUID ? crypto.randomUUID() : String(Date.now()) + Math.random().toString(16).slice(2)); sessionStorage.setItem('mk_sid', sid); }
          let uid = null, isAuth = false;
          try { const { data } = await client.auth.getUser(); if (data && data.user) { uid = data.user.id; isAuth = true; } } catch (e) { /* anon */ }
          const payload = JSON.stringify({ p: location.pathname, r: document.referrer || '', s: sid, u: uid, a: isAuth });
          if (navigator.sendBeacon) navigator.sendBeacon(TRACK_URL, new Blob([payload], { type: 'application/json' }));
          else fetch(TRACK_URL, { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: payload, keepalive: true }).catch(() => {});
        } catch (e) { /* never break the page for analytics */ }
      })();
      window.makorRefreshProgress = async () => {
        const strip = document.getElementById('progress-strip');
        if (!strip) return;
        const { data: u } = await client.auth.getUser();
        if (!u || !u.user) { strip.innerHTML = '<span class="ps-item ps-invite">Sign in to keep your progress. It is free, and always will be.</span>'; strip.hidden = false; return; }
        const rows = await window.makorAllAttempts();
        const totalMeta = document.querySelector('meta[name="makor:total-studies"]');
        const total = totalMeta ? Number(totalMeta.content) : 0;
        const completed = new Set(rows.filter((r) => r.phase === 'post').map((r) => r.study_slug));
        const pct = total ? Math.round((completed.size / total) * 100) : 0;
        let cur = '';
        const metaEl = document.getElementById('study-meta');
        if (metaEl) {
          const slug = metaEl.dataset.slug;
          const mine = rows.filter((r) => r.study_slug === slug);
          const lastPre = [...mine].reverse().find((r) => r.phase === 'pre');
          const lastPost = [...mine].reverse().find((r) => r.phase === 'post');
          if (lastPre || lastPost) {
            cur = '<span class="ps-item">This study: ' + (lastPre ? 'first ' + lastPre.score + '%' : '') + (lastPre && lastPost ? ', ' : '') + (lastPost ? 'after ' + lastPost.score + '%' : '') + '</span>';
          }
        }
        strip.innerHTML = cur + '<span class="ps-item">Progress: ' + completed.size + ' of ' + total + ' studies <span class="ps-bar"><span style="width:' + pct + '%"></span></span> ' + pct + '%</span>';
        strip.hidden = false;
      };

      // Floating sign-in bar: shown to signed-out visitors, hidden once signed in.
      function updateSigninBar(user) {
        const bar = document.getElementById('signin-bar');
        if (!bar) return;
        const dismissed = sessionStorage.getItem('makor_signin_dismissed') === '1';
        bar.hidden = Boolean(user) || dismissed;
      }
      const signinGoogleBtn = document.getElementById('signin-google');
      if (signinGoogleBtn) signinGoogleBtn.addEventListener('click', async () => {
        await client.auth.signInWithOAuth({ provider: 'google', options: { redirectTo: window.location.href } });
      });
      const signinAppleBtn = document.getElementById('signin-apple');
      if (signinAppleBtn) signinAppleBtn.addEventListener('click', async () => {
        await client.auth.signInWithOAuth({ provider: 'apple', options: { redirectTo: window.location.href } });
      });
      const signinDismissBtn = document.getElementById('signin-dismiss');
      if (signinDismissBtn) signinDismissBtn.addEventListener('click', () => {
        sessionStorage.setItem('makor_signin_dismissed', '1');
        const bar = document.getElementById('signin-bar');
        if (bar) bar.hidden = true;
      });

      // Smart header search: titles, references, and full text of written studies.
      (function initSearch() {
        const input = document.getElementById('site-search');
        const results = document.getElementById('search-results');
        if (!input || !results) return;
        let index = null, loading = null, timer = null;
        function load() {
          if (index) return Promise.resolve(index);
          if (!loading) loading = fetch('/search-index.json').then((r) => r.json()).then((d) => { index = d; return d; }).catch(() => { index = []; return []; });
          return loading;
        }
        function esc(s) { return String(s).replace(/[&<>"]/g, (c) => ({ '&': '&amp;', '<': '&lt;', '>': '&gt;', '"': '&quot;' }[c])); }
        function parseRef(q) { const m = q.trim().match(/^([1-3]?\s?[a-z][a-z ]*?)\s*(\d+)(?::(\d+))?$/i); if (!m) return null; return { book: m[1].trim().toLowerCase(), ch: parseInt(m[2], 10), vs: m[3] ? parseInt(m[3], 10) : null }; }
        function inRange(ref, ch, vs) { const mm = ref.match(/(\d+):(\d+)\s*-\s*(?:(\d+):)?(\d+)/); if (!mm) return false; const sc = +mm[1], sv = +mm[2], ec = mm[3] ? +mm[3] : sc, ev = +mm[4]; if (vs == null) return ch >= sc && ch <= ec; const p = ch * 1000 + vs; return p >= sc * 1000 + sv && p <= ec * 1000 + ev; }
        function snippet(text, q) { const t = text.toLowerCase(); const i = t.indexOf(q); if (i < 0) return ''; const s = Math.max(0, i - 30), e = Math.min(text.length, i + q.length + 45); return (s > 0 ? '… ' : '') + text.slice(s, e) + (e < text.length ? ' …' : ''); }
        async function run() {
          const q = input.value.trim();
          if (!q) { results.hidden = true; results.innerHTML = ''; return; }
          const idx = await load();
          const ql = q.toLowerCase();
          const ref = parseRef(q);
          const out = [];
          for (const e of idx) {
            let score = -1, tag = '', snip = '';
            const title = e.title.toLowerCase(), book = e.book.toLowerCase();
            if (ref && (book.startsWith(ref.book) || book.includes(ref.book)) && inRange(e.ref, ref.ch, ref.vs)) { score = 100; tag = 'reference'; }
            if (score < 0) {
              if (book === ql || title === ql) score = 92;
              else if (book.startsWith(ql) || title.startsWith(ql)) score = 82;
              else if (book.includes(ql) || title.includes(ql)) score = 64;
              else if (e.ref.toLowerCase().includes(ql)) score = 58;
              else if (e.available && e.text && e.text.toLowerCase().includes(ql)) { score = 30; tag = 'text'; snip = snippet(e.text, ql); }
            }
            if (score >= 0) out.push({ e, score, tag, snip });
          }
          out.sort((a, b) => b.score - a.score || a.e.i - b.e.i);
          const top = out.slice(0, 12);
          if (!top.length) { results.innerHTML = '<div class="sr-empty">No matches for “' + esc(q) + '”</div>'; results.hidden = false; return; }
          results.innerHTML = top.map(({ e, tag, snip }) => {
            const soon = e.available ? '' : '<span class="sr-soon">soon</span>';
            const tg = tag === 'text' ? '<span class="sr-tag">text</span>' : (tag === 'reference' ? '<span class="sr-tag">reference</span>' : '');
            const sn = snip ? '<div class="sr-snippet">' + esc(snip) + '</div>' : '';
            const href = e.available ? e.url : ('/' + e.bookSlug + '/');
            return '<a class="sr-item" href="' + href + '"><div class="sr-line"><span class="sr-title">' + esc(e.title) + '</span> ' + tg + ' ' + soon + '</div><div class="sr-ref">' + esc(e.book) + ' · ' + esc(e.ref) + '</div>' + sn + '</a>';
          }).join('');
          results.hidden = false;
        }
        input.addEventListener('input', () => { clearTimeout(timer); timer = setTimeout(run, 120); });
        input.addEventListener('focus', () => { load(); if (input.value.trim()) run(); });
        input.addEventListener('keydown', (e) => { if (e.key === 'Escape') { input.value = ''; results.hidden = true; results.innerHTML = ''; input.blur(); } });
        document.addEventListener('click', (e) => { if (results.hidden) return; if (results.contains(e.target) || e.target === input) return; results.hidden = true; });
      })();

      // Minimize / restore the sticky header chrome (search, progress, sign-in) for distraction-free reading.
      (function initHeaderMin() {
        const header = document.querySelector('.site-header');
        const btn = document.getElementById('header-min');
        if (!header || !btn) return;
        function apply(min) {
          header.classList.toggle('header-collapsed', min);
          document.body.classList.toggle('header-collapsed', min);
          btn.setAttribute('aria-expanded', String(!min));
          btn.setAttribute('aria-label', min ? 'Show header' : 'Minimize header');
          btn.setAttribute('title', min ? 'Show' : 'Minimize');
          try { localStorage.setItem('makor_header_min', min ? '1' : '0'); } catch (e) {}
        }
        let min = false;
        try { min = localStorage.getItem('makor_header_min') === '1'; } catch (e) {}
        apply(min);
        btn.addEventListener('click', () => apply(!header.classList.contains('header-collapsed')));
      })();

      const { data: { session } } = await client.auth.getSession();
      render(session ? session.user : null);
      window.makorUser = session ? session.user : null;
      window.makorRefreshProgress();
      window.dispatchEvent(new CustomEvent('makor-auth', { detail: { user: window.makorUser } }));
      client.auth.onAuthStateChange((_e, sess) => {
        window.makorUser = sess ? sess.user : null;
        render(window.makorUser);
        window.makorRefreshProgress();
        window.dispatchEvent(new CustomEvent('makor-auth', { detail: { user: window.makorUser } }));
      });
    </script>
  </body>
</html>
