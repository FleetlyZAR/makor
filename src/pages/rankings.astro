---
import Base from '../layouts/Base.astro';
---
<Base title="Global rankings | Makor" description="How the Makor community is growing in the Word.">
  <section class="hero">
    <p class="eyebrow">Community</p>
    <h1>Global rankings</h1>
    <p class="lead">How the Makor family is growing in the Word. Ranked by studies completed, then by score after study. Growth, not competition; give thanks and keep going.</p>
  </section>

  <p id="rank-status" class="rank-status">Loading the rankings...</p>
  <div id="rank-wrap" hidden>
    <table class="rank-table">
      <thead>
        <tr><th>#</th><th>Name</th><th>Studies</th><th>Before</th><th>After</th></tr>
      </thead>
      <tbody id="rank-body"></tbody>
    </table>
  </div>

  <a class="backlink" href="/">Back to all books</a>
</Base>

<script>
  async function loadRankings() {
    const status = document.getElementById('rank-status');
    const wrap = document.getElementById('rank-wrap');
    const body = document.getElementById('rank-body');
    if (!window.makorClient) return;
    const { data: u } = await window.makorClient.auth.getUser();
    if (!u || !u.user) {
      if (status) { status.hidden = false; status.textContent = 'Open the menu at the top and sign in to see the community rankings.'; }
      if (wrap) wrap.hidden = true;
      return;
    }
    const rows = window.makorLeaderboard ? await window.makorLeaderboard() : [];
    if (!rows || rows.length === 0) {
      if (status) { status.hidden = false; status.textContent = 'No scores yet. Be among the first to complete a study.'; }
      if (wrap) wrap.hidden = true;
      return;
    }
    if (body) {
      body.innerHTML = '';
      rows.forEach((r, i) => {
        const tr = document.createElement('tr');
        const cells = [
          String(i + 1),
          r.display_name || 'Friend',
          String(r.studies_done || 0),
          r.pre_avg == null ? '-' : r.pre_avg + '%',
          r.post_avg == null ? '-' : r.post_avg + '%',
        ];
        cells.forEach((c, ci) => {
          const td = document.createElement('td');
          td.textContent = c;
          if (ci === 1) td.className = 'rank-name';
          tr.appendChild(td);
        });
        body.appendChild(tr);
      });
    }
    if (status) status.hidden = true;
    if (wrap) wrap.hidden = false;
  }
  window.addEventListener('makor-auth', loadRankings);
  loadRankings();
</script>
