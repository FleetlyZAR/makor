---
import Base from '../layouts/Base.astro';
import { getBooks } from '../lib/studies.js';
const books = getBooks();
---
<Base title="Makor | Back to the source" description="Deep, Christ-centred study of every book of the Bible.">
  <section class="hero">
    <p class="eyebrow">Makor</p>
    <h1>Back to the source.</h1>
    <p class="lead">Deep, Christ-centred study of every book of the Bible.</p>
    <p class="motif">In Your light we see light. Psalm 36:9</p>
  </section>

  {books.length === 0 && (
    <p>No studies yet. Add a JSON file under <code>src/content/studies</code> and it will appear here.</p>
  )}

  {books.map((b) => (
    <section class="index-book">
      <h2>{b.book}</h2>
      <ul class="study-list">
        {b.studies.map((s) => (
          <li>
            <a href={`/${b.slug}/${s.section.slug}/`}>{s.section.title}</a>
            <span class="ref"> &nbsp; {s.section.passageRef}</span>
          </li>
        ))}
      </ul>
    </section>
  ))}
</Base>
