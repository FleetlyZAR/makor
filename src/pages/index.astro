---
import Base from '../layouts/Base.astro';
import { getAllStudies, bookSlug } from '../lib/studies.js';
import { books, plans } from '../data/plan.js';

const studies = getAllStudies();
const availableByBook = {};
for (const s of studies) {
  (availableByBook[s.book] ||= new Set()).add(s.section.slug);
}
function movementsFor(bookName) {
  if (plans[bookName]) return plans[bookName];
  return studies
    .filter((s) => s.book === bookName)
    .map((s) => ({ order: s.section.order, ref: s.section.passageRef, title: s.section.title, slug: s.section.slug }));
}
const testaments = [
  { key: 'Old', label: 'Old Testament' },
  { key: 'New', label: 'New Testament' },
];
---
<Base title="Makor | Back to the source" description="Deep, Christ-centred study of every book of the Bible.">
  <section class="hero">
    <p class="eyebrow">Makor</p>
    <h1>Back to the source.</h1>
    <p class="lead">Deep, Christ-centred study of every book of the Bible.</p>
    <p class="motif">In Your light we see light. Psalm 36:9</p>
  </section>

  <section id="resume" class="resume" hidden>
    <div class="resume-inner">
      <p class="resume-eyebrow"></p>
      <h2 class="resume-title"></h2>
      <p class="resume-sub"></p>
      <div class="resume-actions"></div>
      <div class="resume-progress"></div>
    </div>
  </section>

  <section class="info-group">
    <details class="info">
      <summary><span class="info-title">What Makor is</span><span class="chev" aria-hidden="true"></span></summary>
      <div class="info-body">
        <p>Makor (מָקוֹר) is Hebrew for source, spring, wellspring. Scripture calls God the fountain of living waters, and warns against forsaking Him for broken cisterns that hold none (Psalm 36:9; Jeremiah 2:13). Makor exists to bring people back to that source: back to the text, and through the text back to God. It is a deep, Christ-centred study of every book of the Bible, made reachable for working people and not only the seminary trained. Every study works the passage carefully and shows how it points to Christ.</p>
      </div>
    </details>
    <details class="info">
      <summary><span class="info-title">Why movements, not chapters</span><span class="chev" aria-hidden="true"></span></summary>
      <div class="info-body">
        <p>We divide Scripture by its movements, the natural units the authors actually wrote, rather than by chapters. Chapter divisions were added in the thirteenth century and verse numbers in the sixteenth, long after the books were written, purely to help us find a place. They are useful for reference, but they sometimes cut straight through a single movement, or bundle two movements together, which can make us miss the author's point. So we follow the seams the author left, and we still give the chapter and verse references underneath for record keeping.</p>
      </div>
    </details>
    <details class="info">
      <summary><span class="info-title">Why the Berean Standard Bible</span><span class="chev" aria-hidden="true"></span></summary>
      <div class="info-body">
        <p>Our text is the Berean Standard Bible (BSB). It was placed in the public domain in 2023, so we can reproduce it, adapt it, and give it away freely, with no licence, no fee, and no limit on how much we quote. It also ships an aligned Hebrew and Greek interlinear, which powers the original-language notes in each study. Most modern translations are copyrighted, cap free use, and specifically exclude commentary works like this one, so the BSB is what lets Makor stay free and open for everyone.</p>
      </div>
    </details>
  </section>

  <script is:inline type="module">
    // Mark movements the reader has completed (a 'post' attempt) with the green 'done' pill.
    async function markCompleted() {
      if (typeof window.makorAllAttempts !== 'function') return;
      let rows = [];
      try { rows = await window.makorAllAttempts(); } catch (e) { return; }
      const done = new Set((rows || []).filter((r) => r.phase === 'post').map((r) => r.study_slug));
      document.querySelectorAll('.movement-list li.ready a[data-slug]').forEach((a) => {
        if (done.has(a.dataset.slug)) a.classList.add('done');
        else a.classList.remove('done');
      });
    }
    window.addEventListener('makor-auth', markCompleted);
    markCompleted();

    // Resume card: show the reader where they are and where to go next.
    function bar(done, total) {
      const pct = total ? Math.round((done / total) * 100) : 0;
      return '<span class="resume-bartrack"><span style="width:' + pct + '%"></span></span> <span class="resume-count">' + done + ' of ' + total + ' studies</span>';
    }
    async function buildResume() {
      const el = document.getElementById('resume');
      if (!el) return;
      let idx = [];
      try { idx = await fetch('/search-index.json').then((r) => r.json()); } catch (e) {}
      const avail = idx.filter((e) => e.available);
      const total = avail.length;
      const user = window.makorUser;
      let rows = [];
      if (user && typeof window.makorAllAttempts === 'function') { try { rows = await window.makorAllAttempts(); } catch (e) {} }
      const post = new Set(rows.filter((r) => r.phase === 'post').map((r) => r.study_slug));
      const pre = new Set(rows.filter((r) => r.phase === 'pre').map((r) => r.study_slug));
      const eyebrow = el.querySelector('.resume-eyebrow');
      const title = el.querySelector('.resume-title');
      const sub = el.querySelector('.resume-sub');
      const actions = el.querySelector('.resume-actions');
      const prog = el.querySelector('.resume-progress');
      const doneCount = avail.filter((e) => post.has(e.slug)).length;
      const inProgress = avail.find((e) => pre.has(e.slug) && !post.has(e.slug));
      const next = avail.find((e) => !post.has(e.slug));
      const target = inProgress || next;
      if (!user) {
        eyebrow.textContent = 'Welcome to Makor';
        title.textContent = avail[0] ? ('Start with ' + avail[0].book + ': ' + avail[0].title) : 'Start your first study';
        sub.textContent = 'Read your first study, then sign in to save your progress.';
        actions.innerHTML = (avail[0] ? '<a class="btn-primary" href="' + avail[0].url + '">Begin study</a>' : '') + '<a class="btn-secondary" href="#books">Browse all books</a>';
        prog.innerHTML = '';
      } else if (!target) {
        eyebrow.textContent = 'Every available study complete';
        title.textContent = 'You are all caught up';
        sub.textContent = 'More books are on the way. Revisit a study or explore the outline.';
        actions.innerHTML = '<a class="btn-secondary" href="#books">Browse all books</a>';
        prog.innerHTML = bar(doneCount, total);
      } else {
        eyebrow.textContent = inProgress ? 'Continue where you left off' : 'Your next study';
        title.textContent = target.book + ': ' + target.title;
        sub.textContent = target.ref;
        actions.innerHTML = '<a class="btn-primary" href="' + target.url + '">' + (inProgress ? 'Resume study' : 'Start study') + '</a><a class="btn-secondary" href="#books">Browse all books</a>';
        prog.innerHTML = bar(doneCount, total);
      }
      el.hidden = false;
    }
    window.addEventListener('makor-auth', buildResume);
    buildResume();
  </script>

  <div id="books">
  {testaments.map((t) => (
    <section class="testament">
      <h2 class="testament-head">{t.label}</h2>
      {books.filter((b) => b.testament === t.key).map((b) => {
        const movements = movementsFor(b.name);
        const avail = availableByBook[b.name] || new Set();
        const ready = movements.filter((m) => avail.has(m.slug)).length;
        const slug = bookSlug(b.name);
        return (
          <details class="book">
            <summary>
              <span class="book-name">{b.name}</span>
              <span class="book-count">{movements.length ? ready + ' of ' + movements.length : 'soon'}</span>
              <span class="chev" aria-hidden="true"></span>
            </summary>
            <div class="book-body">
              {movements.length === 0 && <p class="soon-note">Studies for this book are coming soon.</p>}
              {movements.length > 0 && (
                <ol class="movement-list">
                  {movements.map((m) => (
                    avail.has(m.slug) ? (
                      <li class="ready">
                        <a data-slug={m.slug} href={`/${slug}/${m.slug}/`}>{m.title}</a>
                        <span class="ref">{m.ref}</span>
                      </li>
                    ) : (
                      <li class="soon">
                        <span class="soon-title">{m.title}</span>
                        <span class="ref">{m.ref}</span>
                        <span class="soon-tag">soon</span>
                      </li>
                    )
                  ))}
                </ol>
              )}
            </div>
          </details>
        );
      })}
    </section>
  ))}
  </div>
</Base>
