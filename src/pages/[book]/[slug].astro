---
import Base from '../../layouts/Base.astro';
import VerseText from '../../components/VerseText.astro';
import { getAllStudies, bookSlug } from '../../lib/studies.js';

export function getStaticPaths() {
  return getAllStudies().map((study) => ({
    params: { book: bookSlug(study.book), slug: study.section.slug },
    props: { study },
  }));
}

const { study } = Astro.props;
const sec = study.section ?? {};
const s = study.study ?? {};
const basic = s.basic ?? {};
const lex = study.lexicon ?? {};
const units = study.text?.units ?? [];
const ctx = s.context ?? {};
const herm = s.hermeneutics ?? {};
const quiz = study.quiz ?? [];
---
<Base title={`${sec.title} | Makor`} description={sec.thesis}>
  <section class="hero">
    <p class="eyebrow">{study.book}</p>
    <h1>{sec.title}</h1>
    <p class="ref">{sec.passageRef}</p>
    {sec.thesis && <p class="thesis">{sec.thesis}</p>}
  </section>

  {sec.sectionRationale && (
    <div class="rationale"><strong>Why this section</strong>{sec.sectionRationale}</div>
  )}
  {sec.frameNote && (
    <div class="rationale"><strong>Structure</strong>{sec.frameNote}</div>
  )}

  <!-- Step 1: read the passage -->
  <p class="step-label">Step 1. Read the passage</p>
  <details class="cascade" open>
    <summary><span class="cascade-title">The passage</span><span class="cascade-ref">{sec.passageRef}</span><span class="chev" aria-hidden="true"></span></summary>
    <div class="cascade-body">
      <div class="scripture">
        {units.map((u) => (
          <div class="unit">
            {u.label && <div class="unit-label">{u.label}{u.note && <span class="unit-note"> &nbsp; {u.note}</span>}</div>}
            <p>{u.verses?.map((v) => <VerseText verse={v} lexicon={lex} />)}</p>
          </div>
        ))}
      </div>
    </div>
  </details>

  <!-- Step 2: pre-test (answers lock, opens the study) -->
  {quiz.length > 0 && (
    <section class="assess" id="pretest">
      <p class="step-label">Step 2. Answer first, before the study</p>
      <p class="assess-intro">Give your best answer to each. Your answers lock once chosen, so this is an honest first attempt. You will answer the same questions again after the study to see what changed.</p>
      <div class="quiz">
        {quiz.map((item, qi) => (
          <div class="quiz-q" data-answered="0">
            <p class="quiz-question">{qi + 1}. {item.q}</p>
            <div class="quiz-options">
              {(item.options ?? []).map((o) => (
                <button class="quiz-opt" type="button" data-weight={o.weight} data-note={o.note}>
                  <span class="opt-text">{o.text}</span>
                  <span class="opt-badge" aria-hidden="true"></span>
                </button>
              ))}
            </div>
            <p class="quiz-feedback" hidden></p>
          </div>
        ))}
      </div>
      <p class="quiz-score" hidden>First score: <span class="quiz-score-val">0</span>% <span class="quiz-score-meta"></span></p>
      <button class="open-study" id="open-study" type="button" hidden>Open the study</button>
    </section>
  )}

  <!-- Step 3: the study (revealed after the pre-test) -->
  <div id="study-gate" class:list={[quiz.length > 0 ? 'gated' : '']} hidden={quiz.length > 0}>
    <p class="step-label">Step 3. Study the passage</p>
    <div class="cascade-controls"><button id="toggle-all" type="button">Open all</button></div>

    <details class="cascade">
      <summary><span class="cascade-title">Context</span><span class="chev" aria-hidden="true"></span></summary>
      <div class="cascade-body">
        {basic.context && <p class="level-basic">{basic.context}</p>}
        {(ctx.literary || ctx.historical || ctx.canonical) && (
          <>
            <button class="go-deeper" type="button">Go deeper</button>
            <div class="level-advanced" hidden>
              {ctx.literary && (<><h3>Literary</h3><p>{ctx.literary}</p></>)}
              {ctx.historical && (<><h3>Historical</h3><p>{ctx.historical}</p></>)}
              {ctx.canonical && (<><h3>Canonical</h3><p>{ctx.canonical}</p></>)}
            </div>
          </>
        )}
      </div>
    </details>

    <details class="cascade">
      <summary><span class="cascade-title">Reading it rightly</span><span class="chev" aria-hidden="true"></span></summary>
      <div class="cascade-body">
        {basic.hermeneutics && <p class="level-basic">{basic.hermeneutics}</p>}
        {(herm.authorIntent || herm.descriptionVsPrescription || (herm.debates ?? []).length > 0) && (
          <>
            <button class="go-deeper" type="button">Go deeper</button>
            <div class="level-advanced" hidden>
              {herm.authorIntent && (<><h3>Author's intent</h3><p>{herm.authorIntent}</p></>)}
              {herm.descriptionVsPrescription && (<><h3>Description and prescription</h3><p>{herm.descriptionVsPrescription}</p></>)}
              {(herm.debates ?? []).length > 0 && <h3>Debates</h3>}
              {(herm.debates ?? []).map((d) => (
                <div class="debate">
                  <p class="q">{d.question}</p>
                  <ul class="pairlist">
                    {(d.views ?? []).map((v) => (<li><span class="k">{v.label}:</span> {v.case}</li>))}
                  </ul>
                  {d.bearing && <p><em>{d.bearing}</em></p>}
                </div>
              ))}
            </div>
          </>
        )}
      </div>
    </details>

    {(basic.originalLanguages || s.originalLanguages || Object.keys(lex).length > 0) && (
      <details class="cascade">
        <summary><span class="cascade-title">The original languages</span><span class="chev" aria-hidden="true"></span></summary>
        <div class="cascade-body">
          {basic.originalLanguages && <p class="level-basic">{basic.originalLanguages}</p>}
          {(s.originalLanguages || Object.keys(lex).length > 0) && (
            <>
              <button class="go-deeper" type="button">Go deeper</button>
              <div class="level-advanced" hidden>
                {s.originalLanguages && <p>{s.originalLanguages}</p>}
                {Object.keys(lex).length > 0 && (
                  <dl class="glossary">
                    {Object.values(lex).map((e) => (
                      <div>
                        <dt>{e.lemma} {e.original && <span class="orig">{e.original}</span>} <span class="lang">({e.language})</span></dt>
                        <dd>{e.gloss}</dd>
                      </div>
                    ))}
                  </dl>
                )}
              </div>
            </>
          )}
        </div>
      </details>
    )}

    {(basic.typology || (s.typology ?? []).length > 0) && (
      <details class="cascade">
        <summary><span class="cascade-title">Types and shadows</span><span class="chev" aria-hidden="true"></span></summary>
        <div class="cascade-body">
          {basic.typology && <p class="level-basic">{basic.typology}</p>}
          {(s.typology ?? []).length > 0 && (
            <>
              <button class="go-deeper" type="button">Go deeper</button>
              <div class="level-advanced" hidden>
                <ul class="pairlist">
                  {s.typology.map((t) => (<li><span class="k">{t.type}:</span> {t.fulfillment}</li>))}
                </ul>
              </div>
            </>
          )}
        </div>
      </details>
    )}

    {(basic.christ || s.christ) && (
      <details class="cascade">
        <summary><span class="cascade-title">Christ as the point</span><span class="chev" aria-hidden="true"></span></summary>
        <div class="cascade-body">
          {basic.christ && <p class="level-basic">{basic.christ}</p>}
          {s.christ && (<><button class="go-deeper" type="button">Go deeper</button><div class="level-advanced" hidden><p>{s.christ}</p></div></>)}
        </div>
      </details>
    )}

    {(basic.god || s.god) && (
      <details class="cascade">
        <summary><span class="cascade-title">What we learn about God</span><span class="chev" aria-hidden="true"></span></summary>
        <div class="cascade-body">
          {basic.god && <p class="level-basic">{basic.god}</p>}
          {s.god && (<><button class="go-deeper" type="button">Go deeper</button><div class="level-advanced" hidden><p>{s.god}</p></div></>)}
        </div>
      </details>
    )}

    {(basic.crossReferences || (s.crossReferences ?? []).length > 0) && (
      <details class="cascade">
        <summary><span class="cascade-title">Cross references</span><span class="chev" aria-hidden="true"></span></summary>
        <div class="cascade-body">
          {basic.crossReferences && <p class="level-basic">{basic.crossReferences}</p>}
          {(s.crossReferences ?? []).length > 0 && (
            <>
              <button class="go-deeper" type="button">Go deeper</button>
              <div class="level-advanced" hidden>
                <ul class="pairlist">
                  {s.crossReferences.map((c) => (<li><span class="k">{c.ref}:</span> {c.note}</li>))}
                </ul>
              </div>
            </>
          )}
        </div>
      </details>
    )}

    {(basic.oneStory || s.oneStory) && (
      <details class="cascade">
        <summary><span class="cascade-title">The one story</span><span class="chev" aria-hidden="true"></span></summary>
        <div class="cascade-body">
          {basic.oneStory && <p class="level-basic">{basic.oneStory}</p>}
          {s.oneStory && (<><button class="go-deeper" type="button">Go deeper</button><div class="level-advanced" hidden><p>{s.oneStory}</p></div></>)}
        </div>
      </details>
    )}

    {(study.translationNotes ?? []).length > 0 && (
      <details class="cascade">
        <summary><span class="cascade-title">Translation notes</span><span class="chev" aria-hidden="true"></span></summary>
        <div class="cascade-body">
          <ul class="pairlist">
            {study.translationNotes.map((n) => (<li><span class="k">{n.ref}:</span> {n.note}</li>))}
          </ul>
        </div>
      </details>
    )}

    <!-- Step 4: post-test -->
    {quiz.length > 0 && (
      <section class="assess" id="posttest">
        <p class="step-label">Step 4. Answer again, after the study</p>
        <p class="assess-intro">The same questions. See how your understanding has grown.</p>
        <div class="quiz">
          {quiz.map((item, qi) => (
            <div class="quiz-q" data-answered="0">
              <p class="quiz-question">{qi + 1}. {item.q}</p>
              <div class="quiz-options">
                {(item.options ?? []).map((o) => (
                  <button class="quiz-opt" type="button" data-weight={o.weight} data-note={o.note}>
                    <span class="opt-text">{o.text}</span>
                    <span class="opt-badge" aria-hidden="true"></span>
                  </button>
                ))}
              </div>
              <p class="quiz-feedback" hidden></p>
            </div>
          ))}
        </div>
        <p class="quiz-score" hidden>Second score: <span class="quiz-score-val">0</span>% <span class="quiz-score-meta"></span></p>
      </section>
    )}

    <!-- Result comparison -->
    <div class="compare" id="compare" hidden>
      <p class="compare-head">What changed today</p>
      <p class="compare-line">Before the study: <span id="pre-out">0</span>%. After the study: <span id="post-out">0</span>%.</p>
      <p class="compare-msg" id="compare-msg"></p>
    </div>

    <!-- Questions for reflection -->
    {(study.questions ?? []).length > 0 && (
      <details class="cascade reflect-section">
        <summary><span class="cascade-title">Questions for reflection</span><span class="chev" aria-hidden="true"></span></summary>
        <div class="cascade-body">
          <ol class="reflect">
            {study.questions.map((q) => (<li>{q}</li>))}
          </ol>
        </div>
      </details>
    )}

    <!-- Sermon (verified), after the reflection questions -->
    {s.sermon && s.sermon.status === 'verified' && (
      <details class="cascade">
        <summary><span class="cascade-title">Listen further</span><span class="chev" aria-hidden="true"></span></summary>
        <div class="cascade-body">
          <div class="sermon">
            <p><strong>{s.sermon.preacher}</strong>: {s.sermon.title}</p>
            {s.sermon.url && <p><a href={s.sermon.url} target="_blank" rel="noopener">Open the sermon</a></p>}
            {s.sermon.why && <p>{s.sermon.why}</p>}
          </div>
        </div>
      </details>
    )}
  </div>

  <a class="backlink" href="/">Back to all books</a>
</Base>

<script>
  function initQuiz(root, onComplete, reveal) {
    if (!root) return;
    root.querySelectorAll('.quiz-options').forEach((group) => {
      Array.from(group.children).sort(() => Math.random() - 0.5).forEach((b) => group.appendChild(b));
    });
    const total = root.querySelectorAll('.quiz-q').length;
    let answered = 0;
    let sum = 0;
    root.addEventListener('click', (e) => {
      const opt = e.target.closest('.quiz-opt');
      if (!opt) return;
      const q = opt.closest('.quiz-q');
      if (!q || q.dataset.answered === '1') return;
      q.dataset.answered = '1';
      const weight = Number(opt.dataset.weight);
      sum += weight;
      answered += 1;
      q.querySelectorAll('.quiz-opt').forEach((o) => {
        o.classList.add('locked');
        if (reveal) {
          const w = Number(o.dataset.weight);
          o.classList.add('w' + w);
          const badge = o.querySelector('.opt-badge');
          if (badge) badge.textContent = w + '%';
        }
      });
      opt.classList.add('chosen');
      if (reveal) {
        const fb = q.querySelector('.quiz-feedback');
        if (fb) { fb.textContent = weight + '%: ' + (opt.dataset.note || ''); fb.hidden = false; }
      }
      const scoreEl = root.querySelector('.quiz-score');
      const val = root.querySelector('.quiz-score-val');
      const meta = root.querySelector('.quiz-score-meta');
      const avg = Math.round(sum / answered);
      if (scoreEl && val) {
        scoreEl.hidden = false;
        val.textContent = avg;
        if (meta) meta.textContent = '(' + answered + ' of ' + total + ' answered)';
      }
      if (answered === total && typeof onComplete === 'function') onComplete(avg);
    });
  }

  let preScore = null;

  const pre = document.getElementById('pretest');
  const gate = document.getElementById('study-gate');
  const openBtn = document.getElementById('open-study');
  initQuiz(pre, (avg) => {
    preScore = avg;
    if (openBtn) openBtn.hidden = false;
  }, false);
  if (openBtn && gate) {
    openBtn.addEventListener('click', () => {
      gate.hidden = false;
      openBtn.disabled = true;
      openBtn.textContent = 'Study opened below';
      gate.scrollIntoView({ behavior: 'smooth', block: 'start' });
    });
  }

  const post = document.getElementById('posttest');
  initQuiz(post, (avg) => {
    const cmp = document.getElementById('compare');
    const preOut = document.getElementById('pre-out');
    const postOut = document.getElementById('post-out');
    const msg = document.getElementById('compare-msg');
    if (preOut) preOut.textContent = preScore == null ? '0' : preScore;
    if (postOut) postOut.textContent = avg;
    if (msg) {
      const delta = preScore == null ? 0 : avg - preScore;
      if (delta > 0) msg.textContent = 'You grew by ' + delta + ' points today. Keep going, and give thanks.';
      else if (delta === 0) msg.textContent = 'Steady. Sit with the passage again and let it deepen.';
      else msg.textContent = 'Scores can dip when questions make us think harder. Return to the passage and the study.';
    }
    if (cmp) { cmp.hidden = false; cmp.scrollIntoView({ behavior: 'smooth', block: 'center' }); }
  }, true);

  // Open all / close all (panels inside the study)
  const btn = document.getElementById('toggle-all');
  function panels() { return Array.from(document.querySelectorAll('#study-gate details.cascade')); }
  function refresh() {
    if (!btn) return;
    const anyClosed = panels().some((p) => !p.open);
    btn.textContent = anyClosed ? 'Open all' : 'Close all';
  }
  if (btn) {
    btn.addEventListener('click', () => {
      const anyClosed = panels().some((p) => !p.open);
      panels().forEach((p) => { p.open = anyClosed; });
      refresh();
    });
    panels().forEach((p) => p.addEventListener('toggle', refresh));
    refresh();
  }

  // Per-panel Go deeper
  document.querySelectorAll('.go-deeper').forEach((b) => {
    b.addEventListener('click', () => {
      const adv = b.nextElementSibling;
      if (!adv || !adv.classList.contains('level-advanced')) return;
      const closed = adv.hasAttribute('hidden');
      if (closed) { adv.removeAttribute('hidden'); b.textContent = 'Show less'; }
      else { adv.setAttribute('hidden', ''); b.textContent = 'Go deeper'; }
    });
  });
</script>
