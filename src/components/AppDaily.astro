---
// Verse of the day card. Appears only in the installed app (Capacitor), only on
// the home page, and only once the reader is signed in. It shows the verse in
// rotation for today with a short devotional and a Share button, using the same
// share cascade as the website daily pages: an image share first, then a text
// and link share, then a copy to clipboard fallback. Never renders on the
// website.
import { dailyEntries } from '../data/daily.js';
---
<script type="application/json" id="app-daily-data" set:html={JSON.stringify(dailyEntries)}></script>
<section id="app-daily" class="ad-card" hidden aria-label="Verse of the day">
  <p class="ad-eyebrow">Verse of the day</p>
  <p id="ad-verse" class="ad-verse"></p>
  <p id="ad-ref" class="ad-ref"></p>
  <div id="ad-story" class="ad-story"></div>
  <div class="ad-actions">
    <a id="ad-study" class="ad-btn ad-primary" href="/">Read the full study</a>
    <button id="ad-share" class="ad-btn ad-share" type="button">Share</button>
  </div>
</section>

<style is:global>
  .ad-card {
    background: var(--surface); border: 1px solid var(--line); border-radius: 16px;
    padding: 18px 18px 16px; margin: 0 0 22px;
  }
  .ad-card[hidden] { display: none; }
  .ad-eyebrow { font-family: var(--sans); font-size: 0.68rem; font-weight: 700; letter-spacing: 0.08em; text-transform: uppercase; color: var(--light); margin: 0 0 8px; }
  .ad-verse { font-family: var(--serif); font-size: 1.35rem; line-height: 1.35; color: var(--ink); margin: 0 0 6px; }
  .ad-ref { font-family: var(--sans); font-size: 0.82rem; font-weight: 600; color: var(--water); margin: 0 0 12px; }
  .ad-story { font-family: var(--serif); font-size: 1rem; line-height: 1.6; color: var(--ink); }
  .ad-story p { margin: 0 0 10px; }
  .ad-actions { display: flex; gap: 10px; margin-top: 14px; flex-wrap: wrap; }
  .ad-btn { font-family: var(--sans); font-size: 0.9rem; font-weight: 600; border-radius: 22px; padding: 11px 18px; cursor: pointer; text-decoration: none; text-align: center; border: 1px solid var(--line); }
  .ad-primary { background: var(--water); color: #fff; border-color: var(--water); }
  .ad-share { background: var(--surface); color: var(--ink); }
</style>

<script is:inline>
  (function () {
    var C = window.Capacitor;
    var isNative = !!(C && C.isNativePlatform && C.isNativePlatform());
    if (!isNative) return; // website never shows this card

    var path = (location.pathname || '/');
    var isHome = path === '/' || path === '' || path === '/index.html';
    if (!isHome) return; // home page only

    var card = document.getElementById('app-daily');
    var dataEl = document.getElementById('app-daily-data');
    if (!card || !dataEl) return;

    var entries = [];
    try { entries = JSON.parse(dataEl.textContent || '[]'); } catch (e) { entries = []; }
    if (!entries.length) return;

    // Deterministic pick per calendar day, so the app matches the daily rotation.
    var now = new Date();
    var start = new Date(now.getFullYear(), 0, 0);
    var day = Math.floor((now - start) / 86400000);
    var entry = entries[day % entries.length];

    var base = 'https://makor.co.za';
    var shareText = '"' + entry.verse + '" (' + entry.ref + ')';
    var shareUrl = base + '/daily/' + entry.slug + '/';
    var imgUrl = base + '/daily/' + entry.slug + '.png';

    // Fill content.
    document.getElementById('ad-verse').textContent = entry.verse;
    document.getElementById('ad-ref').textContent = entry.ref;
    var story = document.getElementById('ad-story');
    story.innerHTML = '';
    (entry.story || []).forEach(function (p) { var el = document.createElement('p'); el.textContent = p; story.appendChild(el); });
    var studyLink = document.getElementById('ad-study');
    if (entry.studyUrl) studyLink.setAttribute('href', entry.studyUrl);

    // Place the card at the top of the main content column.
    var main = document.querySelector('main.wrap') || document.querySelector('main');
    if (main && card.parentNode !== main) { main.insertBefore(card, main.firstChild); }

    // Share cascade: image, then text and link, then clipboard.
    var shareBtn = document.getElementById('ad-share');
    if (shareBtn) shareBtn.addEventListener('click', async function () {
      try {
        if (navigator.canShare) {
          try {
            var r = await fetch(imgUrl);
            var b = await r.blob();
            var f = new File([b], entry.slug + '.png', { type: 'image/png' });
            if (navigator.canShare({ files: [f] })) { await navigator.share({ files: [f], text: shareText + '\n\n' + shareUrl }); return; }
          } catch (e) {}
        }
        if (navigator.share) { await navigator.share({ title: 'Makor', text: shareText, url: shareUrl }); return; }
      } catch (e) { return; }
      try { await navigator.clipboard.writeText(shareText + '\n\n' + shareUrl); alert('Link copied. Paste it anywhere to share.'); }
      catch (e) { window.prompt('Copy this link to share:', shareUrl); }
    });

    // Show only when signed in; keep it in step with auth changes.
    function apply() { card.hidden = !window.makorUser; }
    apply();
    window.addEventListener('makor-auth', apply);
  })();
</script>
