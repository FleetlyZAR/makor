---
// Renders one verse, turning {{lexKey|display}} tokens into tappable lexicon words.
const { verse, lexicon = {} } = Astro.props;
const tokenRe = /\{\{([^|}]+)\|([^}]*)\}\}/g;
const text = verse.text ?? '';
const parts = [];
let last = 0;
let m;
while ((m = tokenRe.exec(text)) !== null) {
  if (m.index > last) parts.push({ type: 'text', value: text.slice(last, m.index) });
  parts.push({ type: 'lex', key: m[1].trim(), display: m[2] });
  last = tokenRe.lastIndex;
}
if (last < text.length) parts.push({ type: 'text', value: text.slice(last) });
---
<span class="verse">
  {verse.n != null && <sup class="vnum">{verse.n}</sup>}
  {parts.map((p) => {
    if (p.type === 'text') return p.value;
    const entry = lexicon[p.key];
    if (!entry) return p.display;
    return (
      <Fragment>
        <button class="lex" type="button" aria-expanded="false">{p.display}</button>
        <span class="lex-pop" hidden>
          <span class="lemma">{entry.lemma}</span>
          {entry.original && <span class="orig">{entry.original}</span>}
          {entry.language && <span class="lang"> ({entry.language})</span>}
          <span class="gloss">{entry.gloss}</span>
        </span>
      </Fragment>
    );
  })}
</span>
