---
// Bottom tab bar. Appears only when running as the installed app (Capacitor),
// never on the website. Order: Home, Plans, Study (centre), Friends, You.
// Home goes to the home page; Study opens the last unfinished study, or the
// first study if there is none. It adds a body.has-tabbar class for bottom
// padding and marks the active tab from location.pathname.
---
<nav class="app-tabbar" id="app-tabbar" hidden aria-label="Main">
  <a class="app-tab" data-tab="home" href="/">
    <svg viewBox="0 0 24 24" aria-hidden="true"><path d="M4 11l8-7 8 7" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linejoin="round"/><path d="M6 10v9h12v-9" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linejoin="round"/></svg>
    <span>Home</span>
  </a>
  <a class="app-tab" data-tab="plans" href="/plan/">
    <svg viewBox="0 0 24 24" aria-hidden="true"><rect x="4" y="5" width="16" height="15" rx="2" fill="none" stroke="currentColor" stroke-width="1.6"/><path d="M4 9h16M8 3v4M16 3v4" stroke="currentColor" stroke-width="1.6" stroke-linecap="round"/></svg>
    <span>Plans</span>
  </a>
  <a class="app-tab" data-tab="study" href="/">
    <svg viewBox="0 0 24 24" aria-hidden="true"><path d="M12 5.5C10 4 6.5 4 4.5 5v13c2-1 5.5-1 7.5.5 2-1.5 5.5-1.5 7.5-.5V5c-2-1-5.5-1-7.5.5z" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linejoin="round"/><path d="M12 5.5V19" stroke="currentColor" stroke-width="1.4"/></svg>
    <span>Study</span>
  </a>
  <a class="app-tab" data-tab="friends" href="/activity/">
    <svg viewBox="0 0 24 24" aria-hidden="true"><circle cx="9" cy="8" r="3.2" fill="none" stroke="currentColor" stroke-width="1.6"/><path d="M3.5 19c.8-3.3 3-4.5 5.5-4.5S13.7 15.7 14.5 19" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round"/><path d="M16 5.2A3 3 0 0117 11" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/></svg>
    <span>Friends</span>
  </a>
  <a class="app-tab" data-tab="profile" href="/profile/">
    <svg viewBox="0 0 24 24" aria-hidden="true"><circle cx="12" cy="8.5" r="3.6" fill="none" stroke="currentColor" stroke-width="1.6"/><path d="M5 20c1-4 4-5.5 7-5.5S18 16 19 20" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round"/></svg>
    <span>You</span>
  </a>
</nav>

<style>
  .app-tabbar {
    position: fixed; left: 0; right: 0; bottom: 0; z-index: 80;
    display: flex;
    background: rgba(246, 243, 236, 0.94);
    -webkit-backdrop-filter: blur(10px); backdrop-filter: blur(10px);
    border-top: 1px solid var(--line);
    padding: 0.4rem 0.25rem calc(0.4rem + env(safe-area-inset-bottom));
  }
  .app-tabbar[hidden] { display: none; }
  .app-tab {
    flex: 1; display: flex; flex-direction: column; align-items: center; gap: 2px;
    text-decoration: none; color: var(--muted);
    font-family: var(--sans); font-size: 0.66rem; font-weight: 600;
    padding: 0.25rem 0;
  }
  .app-tab svg { width: 24px; height: 24px; display: block; }
  .app-tab[aria-current="page"] { color: var(--water); }
  :global(body.has-tabbar) { padding-bottom: 4.75rem; }
  :global(body.has-tabbar) .site-footer { margin-bottom: 1rem; }
</style>

<script is:inline>
  (function () {
    var C = window.Capacitor;
    var isNative = !!(window.makorIsApp && window.makorIsApp());
    if (!isNative) return; // website never shows the tab bar
    var bar = document.getElementById('app-tabbar');
    if (!bar) return;
    document.body.classList.add('has-tabbar');
    bar.hidden = false;

    var p = (location.pathname || '/').replace(/\/+$/, '') || '/';
    var active = 'study';
    if (p === '/' || p === '') active = 'home';
    else if (p.indexOf('/plan') === 0) active = 'plans';
    else if (p.indexOf('/activity') === 0 || p.indexOf('/groups') === 0) active = 'friends';
    else if (p.indexOf('/progress') === 0 || p.indexOf('/profile') === 0) active = 'profile';
    else if (p.indexOf('/admin') === 0 || p.indexOf('/email') === 0 || p.indexOf('/privacy') === 0 || p.indexOf('/terms') === 0 || p.indexOf('/daily') === 0) active = 'home';
    else active = 'study'; // book pages and study pages
    var el = bar.querySelector('[data-tab="' + active + '"]');
    if (el) el.setAttribute('aria-current', 'page');

    // The Study tab opens the most recently opened but unfinished study.
    // If there is none, it opens the first study, Genesis.
    var studyTab = bar.querySelector('[data-tab="study"]');
    if (studyTab) {
      studyTab.addEventListener('click', async function (ev) {
        ev.preventDefault();
        var target = '/genesis/the-seven-days/';
        try {
          var idx = await fetch('/search-index.json').then(function (r) { return r.json(); });
          var avail = idx.filter(function (e) { return e.available; }).sort(function (a, b) { return a.i - b.i; });
          var url = null;
          if (window.makorAllAttempts) {
            var rows = await window.makorAllAttempts();
            if (rows && rows.length) {
              var done = {};
              rows.forEach(function (r) { if (r.phase === 'post') done[r.study_slug] = true; });
              var recent = rows.slice().sort(function (a, b) { return new Date(b.created_at) - new Date(a.created_at); });
              for (var k = 0; k < recent.length; k++) {
                if (!done[recent[k].study_slug]) {
                  var m = avail.find(function (e) { return e.slug === recent[k].study_slug; });
                  if (m) { url = m.url; break; }
                }
              }
            }
          }
          if (!url && avail.length) url = avail[0].url;
          if (url) target = url;
        } catch (e) {}
        location.assign(window.makorHref ? window.makorHref(target) : target);
      });
    }
  })();
</script>
