---
// Header-docked audio player for a study. A slim resting strip that pins under
// whichever header is present (the sticky site header on the website, or the
// fixed studybar in the app), plus a dropdown chapter panel. Reads a per-study
// manifest.json from R2 and hides itself entirely when a study has no audio yet.
//
// Audio host: PUBLIC_MAKOR_AUDIO_BASE (Cloudflare env), default below.
const { book, bookSlug, slug, title } = Astro.props;
const AUDIO_BASE = (import.meta.env.PUBLIC_MAKOR_AUDIO_BASE ?? 'https://audio.makor.co.za/').replace(/\/?$/, '/');
const manifestUrl = `${AUDIO_BASE}studies/${bookSlug}/${slug}/audio/manifest.json`;
---
<section class="mkap" id="mkap" hidden
  data-manifest={manifestUrl} data-slug={slug} data-book={book} data-title={title}>
  <div class="mkap-inner">
    <button class="mkap-play" id="mkap-play" type="button" aria-label="Play">
      <svg viewBox="0 0 24 24" fill="currentColor"><path d="M8 5v14l11-7z"/></svg>
    </button>
    <button class="mkap-now" id="mkap-toggle" type="button" aria-expanded="false" aria-label="Show sections">
      <span class="mkap-eyebrow" id="mkap-eyebrow">Listen to this study</span>
      <span class="mkap-title" id="mkap-title">&nbsp;</span>
    </button>
    <div class="mkap-mini">
      <button class="mkap-skip" id="mkap-rew" type="button" aria-label="Back 90 seconds">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 5V1L6 6l6 5V7a7 7 0 1 1-7 7" stroke-linecap="round" stroke-linejoin="round"/></svg><span>90</span>
      </button>
      <button class="mkap-skip" id="mkap-fwd" type="button" aria-label="Forward 30 seconds">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 5V1l6 5-6 5V7a7 7 0 1 0 7 7" stroke-linecap="round" stroke-linejoin="round"/></svg><span>30</span>
      </button>
      <span class="mkap-time" id="mkap-time">0:00 / 0:00</span>
    </div>
    <button class="mkap-chev" id="mkap-chev" type="button" aria-label="Show sections">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M6 9l6 6 6-6" stroke-linecap="round" stroke-linejoin="round"/></svg>
    </button>
  </div>
  <i class="mkap-prog" id="mkap-prog"></i>

  <div class="mkap-panel" id="mkap-panel" hidden>
    <div class="mkap-panel-inner">
      <div class="mkap-transport">
        <button id="mkap-prev" type="button" aria-label="Previous section"><svg viewBox="0 0 24 24" fill="currentColor"><path d="M6 6h2v12H6zm3.5 6l8.5 6V6z"/></svg></button>
        <button id="mkap-rew2" type="button" aria-label="Back 90 seconds"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 5V1L6 6l6 5V7a7 7 0 1 1-7 7" stroke-linecap="round" stroke-linejoin="round"/></svg></button>
        <button class="big" id="mkap-play2" type="button" aria-label="Play"><svg viewBox="0 0 24 24" fill="currentColor"><path d="M8 5v14l11-7z"/></svg></button>
        <button id="mkap-fwd2" type="button" aria-label="Forward 30 seconds"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 5V1l6 5-6 5V7a7 7 0 1 0 7 7" stroke-linecap="round" stroke-linejoin="round"/></svg></button>
        <button id="mkap-next" type="button" aria-label="Next section"><svg viewBox="0 0 24 24" fill="currentColor"><path d="M16 6h2v12h-2zM6 18l8.5-6L6 6z"/></svg></button>
      </div>
      <div class="mkap-voices" id="mkap-voices"><span class="mkap-vlabel">Voice</span></div>
      <div id="mkap-list"></div>
      <p class="mkap-done" id="mkap-done" hidden>Listened all the way through. Day complete, unscored.</p>
    </div>
  </div>

  <audio id="mkap-audio" preload="metadata"></audio>
</section>

<style is:global>
  .mkap { position: sticky; top: 0; z-index: 45; width: 100vw; margin-left: calc(50% - 50vw); background: var(--surface); border-bottom: 2px solid var(--line); }
  .mkap[hidden] { display: none; }
  .mkap-inner { max-width: var(--maxw, 44rem); margin: 0 auto; display: flex; align-items: center; gap: 12px; padding: 8px 1.25rem; }
  .mkap-play { flex: 0 0 auto; width: 40px; height: 40px; border-radius: 50%; border: none; background: var(--water); color: #fff; display: grid; place-items: center; cursor: pointer; }
  .mkap-play svg { width: 18px; height: 18px; }
  .mkap-now { flex: 1; min-width: 0; background: none; border: none; text-align: left; cursor: pointer; padding: 0; font: inherit; color: var(--ink); display: flex; flex-direction: column; gap: 1px; }
  .mkap-eyebrow { font-family: var(--sans); font-size: 10px; letter-spacing: .16em; text-transform: uppercase; color: var(--light); }
  .mkap-title { font-family: var(--display); font-size: 15px; line-height: 1.15; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
  .mkap-mini { display: flex; align-items: center; gap: 12px; color: var(--muted); }
  .mkap-skip { background: none; border: none; color: var(--muted); cursor: pointer; display: flex; flex-direction: column; align-items: center; font-family: var(--sans); font-size: 8px; line-height: 1; padding: 0; }
  .mkap-skip svg { width: 19px; height: 19px; }
  .mkap-skip span { margin-top: -3px; }
  .mkap-time { font-size: 11px; color: var(--muted); font-variant-numeric: tabular-nums; }
  .mkap-chev { background: none; border: none; color: var(--light); cursor: pointer; flex: 0 0 auto; display: grid; place-items: center; padding: 0; }
  .mkap-chev svg { width: 20px; height: 20px; transition: transform .2s ease; }
  .mkap.open .mkap-chev svg { transform: rotate(180deg); }
  .mkap-prog { position: absolute; left: 0; bottom: -2px; height: 2px; background: var(--light); width: 0; }

  .mkap-panel { position: absolute; left: 0; right: 0; top: 100%; background: var(--surface); border-bottom: 1px solid var(--line); box-shadow: 0 12px 24px rgba(14,42,46,0.10); max-height: 62vh; overflow: auto; }
  .mkap-panel[hidden] { display: none; }
  .mkap-panel-inner { max-width: var(--maxw, 44rem); margin: 0 auto; padding: 10px 1.25rem 18px; }
  .mkap-transport { display: flex; align-items: center; justify-content: center; gap: 18px; padding: 6px 0 10px; }
  .mkap-transport button { background: none; border: none; color: var(--ink); cursor: pointer; display: grid; place-items: center; padding: 0; }
  .mkap-transport svg { width: 22px; height: 22px; }
  .mkap-transport .big { width: 48px; height: 48px; border-radius: 50%; background: var(--water); color: #fff; }
  .mkap-voices { display: flex; flex-wrap: wrap; gap: 8px; align-items: center; padding: 4px 0 2px; }
  .mkap-vlabel { font-family: var(--sans); font-size: 10px; letter-spacing: .12em; text-transform: uppercase; color: var(--muted); margin-right: 2px; }
  .mkap-voice { font-family: var(--sans); font-size: 12px; padding: 4px 12px; border: 1px solid var(--line); border-radius: 999px; background: transparent; color: var(--muted); cursor: pointer; }
  .mkap-voice.sel { background: var(--water); border-color: var(--water); color: #fff; }
  .mkap-group { font-family: var(--sans); font-size: 10px; letter-spacing: .12em; text-transform: uppercase; color: var(--muted); margin: 12px 0 2px; }
  .mkap-seg { display: flex; align-items: center; gap: 10px; width: 100%; text-align: left; background: none; border: none; border-bottom: 1px solid var(--line); padding: 8px 2px; color: var(--ink); font: inherit; cursor: pointer; }
  .mkap-seg:hover, .mkap-seg.active { background: var(--light-soft); }
  .mkap-seg .n { width: 16px; text-align: center; color: var(--light); font-family: var(--display); font-size: 12px; }
  .mkap-seg .lbl { flex: 1; font-family: var(--display); font-size: 14px; }
  .mkap-seg .d { color: var(--muted); font-size: 12px; font-variant-numeric: tabular-nums; }
  .mkap-done { margin: 12px 0 0; background: var(--light-soft); border-radius: 8px; padding: 8px 10px; font-size: 13px; color: var(--ink); }
  .mkap-done[hidden] { display: none; }
  @media (max-width: 560px) { .mkap-mini { display: none; } }
</style>

<script>
  (function () {
    const root = document.getElementById('mkap');
    if (!root) return;
    const audio = document.getElementById('mkap-audio');
    const REWIND = 90, FORWARD = 30;
    const PREFERRED_VOICE = 'am_michael';
    const PLAY = '<svg viewBox="0 0 24 24" fill="currentColor"><path d="M8 5v14l11-7z"/></svg>';
    const PAUSE = '<svg viewBox="0 0 24 24" fill="currentColor"><path d="M6 5h4v14H6zM14 5h4v14h-4z"/></svg>';
    const KIND = { intro: 'Introduction', passage: 'The passage', teaching: 'The study' };

    const meta = { slug: root.dataset.slug, book: root.dataset.book, title: root.dataset.title };
    let M = null, base = '', voice = null, list = [], offsets = [], total = 0, idx = 0, pending = null, savedListen = false;
    const $ = (id) => document.getElementById(id);
    const fmt = (s) => { s = Math.max(0, Math.round(s || 0)); return Math.floor(s / 60) + ':' + String(s % 60).padStart(2, '0'); };

    function setPlayIcons() {
      const html = audio.paused ? PLAY : PAUSE;
      $('mkap-play').innerHTML = html;
      const p2 = $('mkap-play2'); if (p2) p2.innerHTML = html;
    }

    // Dock the strip flush beneath whichever header is currently on screen.
    function dockTop() {
      let bottom = 0;
      ['app-studybar', 'app-appbar'].forEach((id) => {
        const el = document.getElementById(id);
        if (el && !el.hasAttribute('hidden')) { const b = el.getBoundingClientRect().bottom; if (b > bottom) bottom = b; }
      });
      if (bottom === 0) {
        const sh = document.querySelector('.site-header');
        if (sh) { const cs = getComputedStyle(sh); if (cs.display !== 'none' && (cs.position === 'sticky' || cs.position === 'fixed')) bottom = sh.getBoundingClientRect().bottom; }
      }
      root.style.top = Math.max(0, Math.round(bottom)) + 'px';
    }
    let ticking = false;
    function scheduleDock() { if (!ticking) { ticking = true; requestAnimationFrame(() => { dockTop(); ticking = false; }); } }

    function buildPlaylist() {
      list = M.voices[voice].segments.slice();
      offsets = []; total = 0;
      for (const s of list) { offsets.push(total); total += s.seconds || 0; }
    }
    const globalTime = () => (offsets[idx] || 0) + (audio.currentTime || 0);

    function loadTrack(i, within, autoplay) {
      idx = Math.max(0, Math.min(list.length - 1, i));
      const seg = list[idx];
      pending = within || 0;
      audio.src = base + seg.file;
      audio.load();
      if (autoplay) audio.play().catch(() => {});
      $('mkap-eyebrow').textContent = 'Listening · ' + (M.voices[voice].label || voice);
      $('mkap-title').textContent = seg.label;
      renderActive();
      setMediaMeta(seg);
    }
    function seekGlobal(t) {
      t = Math.max(0, Math.min(total, t));
      let i = 0; while (i < list.length - 1 && t >= offsets[i] + (list[i].seconds || 0)) i++;
      const within = t - offsets[i];
      if (i === idx) audio.currentTime = within; else loadTrack(i, within, !audio.paused);
    }

    audio.addEventListener('loadedmetadata', () => { if (pending != null) { try { audio.currentTime = pending; } catch (e) {} pending = null; } });
    audio.addEventListener('timeupdate', () => {
      const gt = globalTime();
      $('mkap-time').textContent = fmt(gt) + ' / ' + fmt(total);
      $('mkap-prog').style.width = (total ? gt / total * 100 : 0) + '%';
      if ('mediaSession' in navigator && audio.duration) {
        try { navigator.mediaSession.setPositionState({ duration: audio.duration, position: audio.currentTime, playbackRate: 1 }); } catch (e) {}
      }
    });
    audio.addEventListener('play', () => { setPlayIcons(); renderActive(); });
    audio.addEventListener('pause', () => { setPlayIcons(); renderActive(); });
    audio.addEventListener('ended', () => { if (idx < list.length - 1) loadTrack(idx + 1, 0, true); else onListenedThrough(); });

    function togglePlay() { if (!audio.src) loadTrack(0, 0, true); else if (audio.paused) audio.play(); else audio.pause(); }
    $('mkap-play').onclick = togglePlay;
    $('mkap-play2').onclick = togglePlay;
    $('mkap-rew').onclick = $('mkap-rew2').onclick = () => seekGlobal(globalTime() - REWIND);
    $('mkap-fwd').onclick = $('mkap-fwd2').onclick = () => seekGlobal(globalTime() + FORWARD);
    $('mkap-prev').onclick = () => { if (globalTime() - (offsets[idx] || 0) > 3 || idx === 0) seekGlobal(offsets[idx] || 0); else loadTrack(idx - 1, 0, !audio.paused); };
    $('mkap-next').onclick = () => { if (idx < list.length - 1) loadTrack(idx + 1, 0, !audio.paused); };

    function togglePanel() {
      const open = root.classList.toggle('open');
      $('mkap-panel').hidden = !open;
      $('mkap-chev').setAttribute('aria-label', open ? 'Hide sections' : 'Show sections');
      $('mkap-toggle').setAttribute('aria-expanded', open ? 'true' : 'false');
    }
    $('mkap-chev').onclick = togglePanel;
    $('mkap-toggle').onclick = togglePanel;

    function renderActive() {
      root.querySelectorAll('.mkap-seg').forEach((el) => el.classList.toggle('active', +el.dataset.i === idx));
    }

    async function onListenedThrough() {
      setPlayIcons();
      $('mkap-done').hidden = false;
      if (savedListen) return;
      savedListen = true;
      if (window.makorSaveAttempt) {
        try {
          await window.makorSaveAttempt({ slug: meta.slug, book: meta.book, title: meta.title, phase: 'listen', score: 0 });
          if (window.makorRefreshProgress) window.makorRefreshProgress();
        } catch (e) {}
      }
      if (window.onMakorListenedThrough) window.onMakorListenedThrough(meta.slug);
    }

    function setMediaMeta(seg) {
      if (!('mediaSession' in navigator)) return;
      try {
        navigator.mediaSession.metadata = new MediaMetadata({
          title: seg.label,
          artist: 'Makor  ·  ' + (M.voices[voice].label || voice),
          album: (M.study.title || '') + '  ·  ' + (M.study.passageRef || ''),
        });
      } catch (e) {}
      const H = (a, fn) => { try { navigator.mediaSession.setActionHandler(a, fn); } catch (e) {} };
      H('play', () => audio.play());
      H('pause', () => audio.pause());
      H('previoustrack', () => $('mkap-prev').click());
      H('nexttrack', () => $('mkap-next').click());
      H('seekbackward', (e) => seekGlobal(globalTime() - ((e && e.seekOffset) || REWIND)));
      H('seekforward', (e) => seekGlobal(globalTime() + ((e && e.seekOffset) || FORWARD)));
      H('seekto', (e) => { if (e.fastSeek && 'fastSeek' in audio) { audio.fastSeek(e.seekTime); return; } audio.currentTime = e.seekTime; });
    }

    function renderList() {
      const box = $('mkap-list'); box.innerHTML = '';
      const groups = [['passage', 'The passage, movement by movement'], ['teaching', 'The study, step by step'], ['intro', 'Introduction']];
      let n = 0;
      groups.forEach(([kind, heading]) => {
        const segs = list.filter((s) => s.kind === kind);
        if (!segs.length) return;
        const h = document.createElement('div'); h.className = 'mkap-group'; h.textContent = heading; box.appendChild(h);
        segs.forEach((seg) => {
          const i = list.indexOf(seg); n++;
          const b = document.createElement('button');
          b.className = 'mkap-seg'; b.dataset.i = i; b.type = 'button';
          b.innerHTML = '<span class="n">' + n + '</span><span class="lbl"></span><span class="d">' + fmt(seg.seconds) + '</span>';
          b.querySelector('.lbl').textContent = seg.label;
          b.onclick = () => loadTrack(i, 0, true);
          box.appendChild(b);
        });
      });
      renderActive();
    }

    function renderVoices() {
      const box = $('mkap-voices');
      box.querySelectorAll('.mkap-voice').forEach((el) => el.remove());
      Object.entries(M.voices).forEach(([id, v]) => {
        const b = document.createElement('button');
        b.className = 'mkap-voice' + (id === voice ? ' sel' : ''); b.textContent = v.label; b.dataset.v = id; b.type = 'button';
        b.onclick = () => switchVoice(id);
        box.appendChild(b);
      });
    }
    function switchVoice(id) {
      if (id === voice) return;
      const gt = globalTime(), wasPlaying = !audio.paused, curId = list[idx].id;
      voice = id;
      root.querySelectorAll('.mkap-voice').forEach((el) => el.classList.toggle('sel', el.dataset.v === id));
      buildPlaylist(); renderList();
      const same = list.findIndex((s) => s.id === curId);
      idx = same >= 0 ? same : 0;
      loadTrack(idx, Math.max(0, gt - (offsets[idx] || 0)), wasPlaying);
    }

    fetch(root.dataset.manifest).then((r) => { if (!r.ok) throw 0; return r.json(); }).then((m) => {
      M = m;
      const murl = root.dataset.manifest;
      const dir = murl.slice(0, murl.lastIndexOf('/') + 1);
      base = m.audioBase ? (m.audioBase.replace(/\/?$/, '/') + (m.studyPath || '')) : dir;
      voice = m.voices[PREFERRED_VOICE] ? PREFERRED_VOICE : (m.defaultVoice || Object.keys(m.voices)[0]);
      $('mkap-title').textContent = m.study.title || 'Study';
      buildPlaylist(); renderVoices(); renderList();
      setPlayIcons();
      root.hidden = false;
      dockTop();
      window.addEventListener('scroll', scheduleDock, { passive: true });
      window.addEventListener('resize', scheduleDock);
    }).catch(() => { /* no audio for this study yet: stay hidden */ });
  })();
</script>
